/* Exit to Home */
window.exitToHome = function() {
  if (confirm('Yakin ingin kembali ke Home?')) {
    window.location.href = 'index.html';
  }
};

/* Populate Products from product.js */
window.populateProducts = function() {
  const select = document.getElementById('productSelect');
  if (!select || typeof products === 'undefined') return;
  
  const categoryMap = {};
  if (typeof categories !== 'undefined') {
    categories.forEach(cat => {
      categoryMap[cat.id] = cat.name;
    });
  }
  
  select.innerHTML = '<option value="">📦 Pilih Produk</option>';
  
  const grouped = {};
  products.forEach(product => {
    const cat = product.category || 'other';
    if (!grouped[cat]) grouped[cat] = [];
    grouped[cat].push(product);
  });
  
  Object.keys(grouped).forEach(catId => {
    const optgroup = document.createElement('optgroup');
    optgroup.label = categoryMap[catId] || catId;
    
    grouped[catId].forEach(product => {
      const option = document.createElement('option');
      option.value = JSON.stringify({ name: product.name, price: product.price, desc: product.desc });
      option.textContent = `${product.name} - ${product.price}`;
      optgroup.appendChild(option);
    });
    
    select.appendChild(optgroup);
  });
};

document.addEventListener('DOMContentLoaded', function() {
  if (typeof window.populateProducts === 'function') {
    window.populateProducts();
  }
});

