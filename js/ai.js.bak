// js/ai.js
// ============================================================================

/**
 * AI Assistant untuk FahriXZ Store
 * Menggunakan free AI API untuk menghemat biaya
 */

// Konfigurasi AI
const AI_CONFIG = {
  // Gunakan API gratis atau proxy untuk避免 expose API key
  // Opsi 1: Free API (tidak perlu API key)
  apiEndpoint: "https://api.dify.ai/v1/chat-messages",
  // Opsi 2: OpenAI (butuh API key - gunakan environment variable)
  // apiEndpoint: "https://api.openai.com/v1/chat/completions",
  
  // Untuk production, simpan API key di server, bukan di client!
  maxTokens: 500,
  temperature: 0.7,
};

// Simpan jawaban AI sebelumnya untuk konteks
let conversationHistory = [];

/**
 * Tanya AI Assistant
 * @param {string} prompt - Pertanyaan user
 * @returns {object} - { success: boolean, response: string, error?: string }
 */
export async function askAI(prompt) {
  try {
    // Validasi input
    if (!prompt || typeof prompt !== 'string') {
      return { 
        success: false, 
        response: null, 
        error: 'Prompt tidak valid' 
      };
    }

    // Sanitize input
    const sanitizedPrompt = prompt.trim().slice(0, 1000);
    
    if (sanitizedPrompt.length < 2) {
      return { 
        success: false, 
        response: null, 
        error: 'Prompt terlalu pendek' 
      };
    }

    // Show loading indicator
    showLoadingAI(true);

    // Add to history
    conversationHistory.push({
      role: 'user',
      content: sanitizedPrompt
    });

    // Prepare messages for API
    const messages = [
      {
        role: 'system',
        content: `Kamu adalah AI Assistant untuk FahriXZ Store. 
Jawab dengan sopan dan helpful dalam bahasa Indonesia. 
FahriXZ Store menyediakan jasa digital seperti:
- Upgrade Dana Premium
- QRIS Merchant
- Video Editing
- Website Premium
- UI Design

Selalu jawab secara singkat dan jelas.`
      },
      ...conversationHistory.slice(-5) // Keep last 5 messages for context
    ];

    // Fetch response
    const response = await fetch(AI_CONFIG.apiEndpoint, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        // 'Authorization': `Bearer ${process.env.OPENAI_API_KEY}` // Di server!
      },
      body: JSON.stringify({
        query: sanitizedPrompt,
        conversation_id: sessionStorage.getItem('ai_conversation_id') || null,
        response_mode: 'blocking'
      })
    });

    if (!response.ok) {
      throw new Error(`API Error: ${response.status}`);
    }

    const data = await response.json();

    // Extract response
    const aiResponse = data.answer || data.content || data.message || data.choices?.[0]?.message?.content;

    if (!aiResponse) {
      throw new Error('Tidak ada response dari AI');
    }

    // Add AI response to history
    conversationHistory.push({
      role: 'assistant',
      content: aiResponse
    });

    // Save conversation ID if available
    if (data.conversation_id) {
      sessionStorage.setItem('ai_conversation_id', data.conversation_id);
    }

    // Keep history limited
    if (conversationHistory.length > 10) {
      conversationHistory = conversationHistory.slice(-10);
    }

    showLoadingAI(false);
    
    return {
      success: true,
      response: aiResponse,
      error: null
    };

  } catch (error) {
    console.error('AI Error:', error);
    showLoadingAI(false);
    
    return {
      success: false,
      response: null,
      error: error.message || 'Terjadi kesalahan'
    };
  }
}

/**
 * Tampilkan loading indicator
 */
function showLoadingAI(show) {
  const resultDiv = document.getElementById('aiResult');
  if (resultDiv) {
    if (show) {
      resultDiv.innerHTML = '<div class="ai-loading">🤔 Memikirkan...</div>';
    }
  }
}

/**
 * Reset conversation
 */
export function resetAIConversation() {
  conversationHistory = [];
  sessionStorage.removeItem('ai_conversation_id');
  
  const resultDiv = document.getElementById('aiResult');
  if (resultDiv) {
    resultDiv.innerHTML = '';
  }
  
  console.log("✅ Conversation reset!");