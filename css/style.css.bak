FAHRIXZ STORE - GAMING LUXURY STYLE
============================ */

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --primary: #00d9ff;
  --primary-dark: #00a8cc;
  --secondary: #667eea;
  --bg-dark: #0a0a0f;
  --bg-card: #12121a;
  --bg-input: #1a1a25;
  --text-white: #ffffff;
  --text-gray: #a0a0b0;
  --border: rgba(0, 217, 255, 0.2);
  --success: #22c55e;
  --error: #ef4444;
  --warning: #f59e0b;
}

body {
  background: var(--bg-dark);
  color: var(--text-white);
