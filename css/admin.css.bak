*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
background:#020617;
color:white;
}

.admin-dashboard{
display:flex;
min-height:100vh;
}

/* SIDEBAR */

.admin-sidebar{

width:280px;

background:#0f172a;

padding:30px;

display:flex;

flex-direction:column;

gap:15px;

border-right:
1px solid rgba(255,255,255,.1);

}

.admin-sidebar h2{
margin-bottom:20px;
}

.admin-sidebar a{

padding:14px;

border-radius:14px;

text-decoration:none;

color:white;

transition:.3s;

}

.admin-sidebar a:hover{
background:#1e293b;
}

.admin-sidebar button{

margin-top:auto;

padding:14px;

border:none;

border-radius:14px;

background:#dc2626;

color:white;

cursor:pointer;

}

/* CONTENT */

.admin-content{
flex:1;
padding:40px;
}

.admin-stats{

display:grid;

grid-template-columns:
repeat(auto-fit,minmax(220px,1fr));

gap:20px;

margin-top:30px;

}

.admin-card{

background:#0f172a;

padding:25px;

border-radius:24px;

text-align:center;

transition:.3s;

}

.admin-card:hover{

transform:translateY(-5px);

box-shadow:
0 0 20px rgba(37,99,235,.3);

}

.admin-box{

margin-top:30px;

background:#0f172a;

padding:25px;

border-radius:24px;

display:flex;

flex-direction:column;

gap:15px;

}

.admin-box input,
.admin-box select{

padding:14px;

border:none;

border-radius:14px;

background:#1e293b;

color:white;

}

.admin-box button{

padding:14px;

border:none;

border-radius:14px;

background:#2563eb;

color:white;

cursor:pointer;

}

.order-admin-card{

background:#111827;

padding:20px;

border-radius:18px;

margin-top:15px;

}

/* =========================
TEXTAREA
========================= */

textarea{

width:100%;

min-height:180px;

padding:18px;

border:none;

border-radius:18px;

background:#1e293b;

color:white;

resize:none;

}