/* =========================
RESPONSIVE - FAHRIXZ STORE
============================ */

/* Tablet */
@media (max-width: 992px) {
  .hero {
    grid-template-columns: 1fr;
    text-align: center;
    padding: 40px 5%;
  }
  
  .hero-image {
    max-width: 500px;
    margin: auto;
  }
  
  .navbar {
    flex-direction: column;
    gap: 15px;
  }
  
  .nav-links {
    flex-wrap: wrap;
    justify-content: center;
  }
  
  .stats {
    grid-template-columns: 1fr 1fr;
  }
  
  .dashboard,
  .admin-dashboard {
    flex-direction: column;
  }
}

/* Mobile */
@media (max-width: 768px) {
  .nav-links {
    display: none;
  }
  
  .hero {
    padding: 30px 5%;
  }
  
  .hero h1 {
    font-size: 2rem;
  }
  
  .product-grid {
    grid-template-columns: 1fr;
  }
  
  .stats {
    grid-template-columns: 1fr;
  }
  
  .stats-card h1,
  .stats-card h2 {
    font-size: 1.8rem;
  }
  
  .track-form {
    flex-direction: column;
  }
  
  .order-container {
    padding: 20px;
  }
  
  .invoice-box {
    padding: 20px;
  }
  
  .sidebar,
  .admin-sidebar {
    width: 100%;
    flex-direction: row;
    overflow-x: auto;
    gap: 10px;
  }
  
  .sidebar a,
  .admin-sidebar a {
    white-space: nowrap;
    padding: 10px 15px;
  }
  
  .content,
  .admin-content {
    padding: 20px;
  }
  
  .category-filter {
    overflow-x: auto;
    flex