*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
background:#020617;
color:white;
min-height:100vh;
}

.dashboard{
display:flex;
min-height:100vh;
}

/* =========================
TRACKING STEP
========================= */

.tracking-step{

padding:14px;

margin-top:10px;

border-radius:12px;

background:#1e293b;

}

.tracking-step.active{

background:#2563eb;

}

/* =========================
INVOICE
========================= */

.invoice-container{

display:flex;

justify-content:center;

align-items:center;

min-height:100vh;

background:#020617;

padding:20px;

}

.invoice-box{

width:100%;

max-width:600px;

background:#0f172a;

padding:40px;

border-radius:24px;

color:white;

}

.invoice-box h1{

margin-bottom:30px;

}

.invoice-item{

display:flex;

justify-content:space-between;

margin-bottom:20px;

padding-bottom:10px;

border-bottom:
1px solid rgba(255,255,255,.05);

}

.invoice-box button{

width:100%;

margin-top:20px;

padding:16px;

border:none;

border-radius:14px;

background:#2563eb;

color:white;

cursor:pointer;

}

/* SIDEBAR */

.sidebar{

width:260px;

background:#0f172a;

padding:30px;

display:flex;

flex-direction:column;

gap:15px;

border-right:
1px solid rgba(255,255,255,.1);

}

.sidebar h2{
margin-bottom:30px;
}

.sidebar a{

padding:14px;

border-radius:14px;

text-decoration:none;

color:white;

transition:.3s;

}

.sidebar a:hover{
background:#1e293b;
}

.sidebar button{

margin-top:auto;

padding:14px;

border:none;

border-radius:14px;

background:#dc2626;

color:white;

cursor:pointer;

}

/* CONTENT */

.content{
flex:1;
padding:40px;
}

.profile-box{

background:rgba(255,255,255,.05);

padding:25px;

border-radius:24px;

margin-top:20px;

backdrop-filter:blur(20px);

}

.stats-grid{

display:grid;

grid-template-columns:
repeat(auto-fit,minmax(220px,1fr));

gap:20px;

margin-top:30px;

}

.stats-card{

background:#0f172a;

padding:25px;

border-radius:20px;

text-align:center;

transition:.3s;

}

.stats-card:hover{

transform:translateY(-5px);

box-shadow:
0 0 20px rgba(37,99,235,.3);

}

.tracking-box,
.order-box{

margin-top:30px;

background:#0f172a;

padding:25px;

border-radius:24px;

}

.track-form{

display:flex;

gap:10px;

margin-top:20px;

}

.track-form input{

flex:1;

padding:14px;

border:none;

border-radius:14px;

background:#1e293b;

color:white;

}

.track-form button{

padding:14px 20px;

border:none;

border-radius:14px;

background:#2563eb;

color:white;

cursor:pointer;

}

#orderList{
margin-top:20px;
display:grid;
gap:15px;
}

.order-card{

background:#111827;

padding:20px;

border-radius:18px;

}

/* =========================
CHAT SYSTEM
========================= */

.chat-box{

background:#0f172a;

border-radius:24px;

padding:20px;

height:600px;

display:flex;

flex-direction:column;

}

#chatMessages{

flex:1;

overflow:auto;

padding-right:10px;

}

.chat-message{

padding:14px 18px;

border-radius:18px;

margin-bottom:15px;

max-width:70%;

word-wrap:break-word;

}

.chat-message.user{

background:#2563eb;

margin-left:auto;

}

.chat-message.admin{

background:#1e293b;

}

.chat-input{

display:flex;

gap:10px;

margin-top:15px;

}

.chat-input input{

flex:1;

padding:14px;

border:none;

border-radius:14px;

background:#1e293b;

color:white;

}

.chat-input button{

padding:14px 20px;

border:none;

border-radius:14px;

background:#2563eb;

color:white;

cursor:pointer;

}

/* =========================
ORDER PAGE
========================= */

.order-page{

min-height:100vh;

display:flex;

justify-content:center;

align-items:center;

padding:30px;

}

.order-container{

width:100%;
max-width:700px;

background:#0f172a;

padding:30px;

border-radius:30px;

display:flex;

flex-direction:column;

gap:15px;

}

.order-container input,
.order-container textarea,
.order-container select{

padding:16px;

border:none;

border-radius:14px;

background:#1e293b;

color:white;

}

.order-container textarea{

height:140px;

resize:none;

}

.order-container button{

padding:16px;

border:none;

border-radius:14px;

background:#2563eb;

color:white;

cursor:pointer;

}

/* =========================
REVIEW
========================= */

#reviewContainer{

margin-top:30px;

display:flex;

flex-direction:column;

gap:20px;

}

/* =========================
NOTIFICATION
========================= */

.notification-container{

margin-top:30px;

}

.notification-card{

background:#0f172a;

padding:25px;

border-radius:24px;

}

.notif-item{

padding:15px;

border-radius:14px;

background:#111827;

margin-top:15px;

display:flex;

justify-content:space-between;

align-items:center;

}

.notif-item span{

font-size:13px;

color:#94a3b8;

}


/* =========================
INVOICE
========================= */

.invoice-page{

min-height:100vh;

display:flex;

justify-content:center;

align-items:center;

padding:30px;

}

.invoice-box{

width:100%;
max-width:600px;

background:#0f172a;

padding:40px;

border-radius:30px;

}

.invoice-detail{

margin-top:25px;

display:grid;

gap:15px;

}

.invoice-box button{

margin-top:30px;

padding:16px;

border:none;

border-radius:14px;

background:#22c55e;

color:white;

cursor:pointer;

}