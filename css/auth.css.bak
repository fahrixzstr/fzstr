*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
background:#020617;
min-height:100vh;
display:flex;
justify-content:center;
align-items:center;
padding:20px;
overflow:hidden;
}

.auth-container{
width:100%;
max-width:450px;
}

.auth-card{

background:rgba(255,255,255,.05);

border:1px solid rgba(255,255,255,.1);

backdrop-filter:blur(20px);

padding:40px;

border-radius:30px;

box-shadow:
0 0 40px rgba(37,99,235,.2);

animation:fadeUp .7s ease;

}

.auth-card h1{
font-size:35px;
margin-bottom:10px;
color:white;
}

.auth-card p{
color:#94a3b8;
margin-bottom:30px;
}

.auth-card input{

width:100%;

padding:16px;

margin-bottom:15px;

border:none;

border-radius:16px;

background:#0f172a;

color:white;

font-size:15px;

outline:none;

}

.auth-card button{

width:100%;

padding:16px;

border:none;

border-radius:16px;

background:#2563eb;

color:white;

font-size:16px;

font-weight:600;

cursor:pointer;

margin-bottom:15px;

transition:.3s;

}

.auth-card button:hover{

transform:translateY(-3px);

box-shadow:
0 0 20px rgba(37,99,235,.4);

}

.google-btn{
background:#dc2626 !important;
}

.auth-footer{

text-align:center;

margin-top:20px;

color:#cbd5e1;

}

.auth-footer a{

color:#60a5fa;

text-decoration:none;

font-weight:600;

}

@keyframes fadeUp{

from{

opacity:0;
transform:translateY(30px);

}

to{

opacity:1;
transform:translateY(0px);

}

/* =========================
CAPTCHA
========================= */

.captcha-box{

margin-top:15px;

}

#captchaText{

background:#2563eb;

padding:15px;

border-radius:14px;

text-align:center;

letter-spacing:5px;

margin-bottom:10px;

}

}